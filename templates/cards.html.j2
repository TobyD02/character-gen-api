<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Character Roster</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@900&family=Cinzel:wght@700&family=Rajdhani:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/static/css/cards.css">

    <style>
        body {
            background: #04090d;
            font-family: 'Rajdhani', sans-serif;
            color: #e8dfc8;
        }

        .page-header {
            text-align: center;
            padding: 25px 20px 30px;
        }

        .page-header h1 {
            font-family: 'Cinzel Decorative', serif;
            font-size: 26px;
            color: #d4a843;
            letter-spacing: 3px;
        }

        .page-header p {
            font-size: 11px;
            color: #8a8070;
            margin-top: 4px;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        /* Responsive Container */
        .cards-viewport {
            padding-bottom: 50px;
        }

        /* Ensure card fits in column */
        .card-wrapper {
            display: flex;
            justify-content: center;
        }
    </style>
</head>

<body>

<header class="page-header">
    <h1>Active Roster</h1>
    <p>Combat Status Summary</p>
</header>

<main class="container-fluid cards-viewport">
    <div class="row row-cols-auto g-4 justify-content-center">

        {% for member in characters %}
            {% set character = member.character %}
            {% set character_profile = member.character_profile %}
            {% set powerscale = member.powerscale %}
            {% set special_abilities = member.special_abilities %}

            <div class="row g-4 justify-content-center">
                {% include 'partials/card_partial.html.j2' %}
            </div>
        {% endfor %}

    </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
