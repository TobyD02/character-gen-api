<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Character Roster</title>

    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700;900&family=Rajdhani:wght@300;400;500;600;700&display=swap"
          rel="stylesheet"/>

    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background: #04090d;
            font-family: 'Rajdhani', sans-serif;
            color: #e8dfc8;
            overflow-x: hidden; /* 🧯 kills horizontal scroll */
        }

        .page-header {
            text-align: center;
            padding: 25px 20px 10px;
        }

        .page-header h1 {
            font-family: 'Cinzel Decorative', serif;
            font-size: 26px;
            color: #d4a843;
            letter-spacing: 3px;
        }

        .page-header p {
            font-size: 11px;
            color: #8a8070;
            margin-top: 4px;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        .cards-viewport {
            width: 100%;
            height: calc(100vh - 100px);
            overflow-y: auto;

            display: grid;

            /* ✅ KEY FIX */
            grid-template-columns: repeat(auto-fit, minmax(840px, 840px));

            justify-content: center;
            gap: 14px 18px;
            padding: 20px;

            overflow-x: hidden; /* extra safety */
        }

        .card {
            width: 840px;
            height: 400px;
        }
    </style>
</head>

<body>

<header class="page-header">
    <h1>Active Roster</h1>
    <p>Combat Status Summary</p>
</header>

<main class="cards-viewport">

    {% for member in characters %}
        {% set character = member.character %}
        {% set character_profile = member.character_profile %}
        {% set powerscale = member.powerscale %}
        {% set special_abilities = member.special_abilities %}

        {% include 'partials/card_partial.html.j2' %}
    {% endfor %}

</main>

</body>
</html>
